[Unit]
PartOf=graphical-session.target
After=graphical-session.target
Requisite=graphical-session.target

[Service]
ExecStart=/usr/bin/swayidle -w timeout 600 'gtklock -d' timeout 601 'niri msg action power-off-monitors' resume 'niri msg action power-on-monitors' before-sleep 'gtklock -d'
Restart=on-failure

